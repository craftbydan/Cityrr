{
  "manifest_version": 3,
  "name": "DOM AI",
  "version": "1.0.0",
  "description": "AI-powered DOM agent that sees your page and clicks elements using GPT-5.4 nano",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["https://api.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DOM AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/dom-snapshot.js", "lib/actions.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
